{
  "name": "design-system",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "preview": "npm -w @ds/preview run dev",
    "storybook": "turbo run storybook --filter=@ds/storybook",
    "tokens:sync": "turbo run tokens:sync --filter=@ds/tokens",
    "code-connect:publish": "turbo run code-connect:publish --filter=@ds/code-connect",
    "code-connect:unpublish": "turbo run code-connect:unpublish --filter=@ds/code-connect",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0",
    "@types/node": "^20.0.0"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
