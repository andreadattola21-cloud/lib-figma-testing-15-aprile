{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "tokens:sync": {
      "cache": false,
      "outputs": ["src/generated/**"]
    },
    "code-connect:publish": {
      "cache": false
    },
    "code-connect:unpublish": {
      "cache": false
    }
  }
}
